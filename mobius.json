{
  "id": "news",
  "name": "News",
  "version": "1.1.0",
  "description": "Daily AI-curated news digest. Customize what to search for and the delivery schedule from inside the app.",
  "author": "mobius-os",
  "license": "MIT",
  "homepage": "https://github.com/mobius-os/app-news",
  "icon": "icon.png",
  "entry": "index.jsx",
  "permissions": {
    "cross_app_access": "none",
    "share_with_apps": "none"
  },
  "storage_seeds": {
    "system-prompt.md": "system-prompt.md",
    "topics.txt": "topics.txt",
    "schedule.json": {
      "hour": 10,
      "minute": 0
    }
  },
  "schedule": {
    "default": "0 10 * * *",
    "user_configurable": true,
    "job": "fetch.sh"
  },
  "runtime": {
    "imports": ["react", "react-dom"]
  }
}
